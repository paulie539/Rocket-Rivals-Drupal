# Drupal uploaded files
/sites/default/files/

# Composer dependencies
/vendor/

# Local settings
/sites/default/settings.local.php

# Node modules (if any)
node_modules/

# OS temp files
.DS_Store
*.log
*.tmp

# IDE/editor files
.idea/
*.sublime-project
*.sublime-workspace

# ── Ignore Drupal specific directories (auto-generated) ──
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/sites/*/files/
/web/sites/*/private/
/web/sites/*/files-private/

# ── Keep composer.json and composer.lock (source files) ──
!/composer.json
!/composer.lock

# ── Ignore local environment-specific files (secrets) ──
.env
.env.local
# /web/sites/default/settings.php  # Unignored for Pantheon deployment
/web/sites/default/settings.local.php
/web/sites/*/services.local.yml

# ── Ignore logs and temporary files ──
*.log
*.tmp
*.swp
*.swo
*~

# ── Ignore OS generated files ──
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Ignore IDE/editor files ──
.idea/
*.iml
*.sublime-project
*.sublime-workspace
.vscode/
*.code-workspace

# ── Ignore Sass/SCSS cache  ──
.sass-cache/
*.css.map

# ── Ignore Claude data  ──
.claude
CLAUDE.md

# ── Database and archive dumps ──
*.sql.gz
*.tar.gz
*.sql

# ── Local settings (not committed) ──
/web/sites/default/settings.local.php
/web/sites/default/settings.ddev.php
