{#
/**
 * @file
 * Renders the main navigation as the hero nav overlay (top-right).
 *
 * External links (e.g. Discord) open in a new tab automatically.
 * The Discord link gets the .discord-button pill style by detecting
 * "discord" in its URL.
 *
 * Variables:
 * - items: A nested list of the menu's items.
 *   Each item contains:
 *   - attributes: HTML attributes for the menu item link.
 *   - below: The item's sub-menu, if any.
 *   - title: The menu link title.
 *   - url: The menu link URL object.
 *   - in_active_trail: Whether this link is in the active trail.
 */
#}
<nav class="hero-nav" aria-label="{{ 'Site navigation'|t }}">
  {{ attach_library('rr_background/live_status') }}
  {% for item in items %}
    {%
      set is_discord = 'discord' in item.url.toString()
    %}
    {%
      set is_schedule = 'schedule' in item.url.toString()
    %}
    {% if is_schedule %}
      <span class="rr-nav-schedule-wrapper">
        <a href="{{ item.url }}"
           {% if item.in_active_trail %}aria-current="page"{% endif %}>
          {{- item.title -}}
        </a>
        <div id="rr-live-status" aria-live="polite" aria-atomic="true"></div>
      </span>
    {% else %}
      <a href="{{ item.url }}"
         {% if is_discord %}class="discord-button"{% endif %}
         {% if item.url.isExternal() %}target="_blank" rel="noopener noreferrer"{% endif %}
         {% if item.in_active_trail %}aria-current="page"{% endif %}>
        {{- item.title -}}
      </a>
    {% endif %}
  {% endfor %}
</nav>
